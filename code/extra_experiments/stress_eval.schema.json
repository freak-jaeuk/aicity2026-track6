{
    "name": "scripts/stress_eval.py",
    "cmd": "python scripts/stress_eval.py",
    "json_schema": {
        "$defs": {
            "InferenceConfig": {
                "properties": {
                    "compile": {
                        "default": true,
                        "title": "Compile",
                        "type": "boolean"
                    },
                    "batch_size": {
                        "default": 1,
                        "title": "Batch Size",
                        "type": "integer"
                    },
                    "threshold": {
                        "default": 0.01,
                        "title": "Threshold",
                        "type": "number"
                    },
                    "hflip": {
                        "default": false,
                        "title": "Hflip",
                        "type": "boolean"
                    },
                    "num_select": {
                        "anyOf": [
                            {
                                "type": "integer",
                                "title": "Select 'Integer'"
                            },
                            {
                                "type": "null",
                                "title": "Select None"
                            }
                        ],
                        "default": null,
                        "title": "Num Select"
                    }
                },
                "title": "InferenceConfig",
                "type": "object"
            }
        },
        "description": "Evaluate a checkpoint on corrupted SOURCE-VAL and log per-corruption COCO mAP.\n\nLoads the dataset (hidden dataset on the platform, small public sample locally), takes the\nVAL split (which has ground truth), and for each corruption runs inference + COCO metrics.\nEmits per-corruption mAP/mAP_m/mAP_l/AR_100 plus a clean-vs-corruption robustness summary.",
        "properties": {
            "project_name": {
                "default": "Stress Eval RF-DETR",
                "description": "Project name for the experiment",
                "title": "Project Name",
                "type": "string"
            },
            "model_path": {
                "default": "./pretrained_models/RFDETRLarge.zip",
                "description": "Path to a compressed (zip) model archive to evaluate. IGNORED when a checkpoint is attached to the experiment on the Hafnia platform (that checkpoint is used instead).",
                "title": "Model Path",
                "type": "string"
            },
            "samples": {
                "anyOf": [
                    {
                        "type": "integer",
                        "title": "Select 'Integer'"
                    },
                    {
                        "type": "null",
                        "title": "Select None"
                    }
                ],
                "default": null,
                "description": "Cap the number of VAL samples (deterministic subset, seed 42). Omit to use all. ~1500 is a good platform default.",
                "title": "Samples"
            },
            "inference_config": {
                "anyOf": [
                    {
                        "$ref": "#/$defs/InferenceConfig"
                    },
                    {
                        "type": "null",
                        "title": "Select None"
                    }
                ],
                "default": null,
                "description": "Inference config (threshold / num_select / hflip / compile). Reuse to probe their effect on val."
            },
            "seed": {
                "default": 1234,
                "description": "Corruption sampling seed (identical across checkpoints for fair comparison)",
                "title": "Seed",
                "type": "integer"
            },
            "corruptions": {
                "anyOf": [
                    {
                        "type": "string",
                        "title": "Select 'String'"
                    },
                    {
                        "type": "null",
                        "title": "Select None"
                    }
                ],
                "default": null,
                "description": "Comma-separated subset of corruptions to run (default: all). 'clean' is always included.",
                "title": "Corruptions"
            }
        },
        "title": "mainArgs",
        "type": "object",
        "positional_args": []
    },
    "case_conversion": "kebab",
    "parameter_prefix": "--",
    "nested_parameter_handling": "dot",
    "assignment_separator": "space",
    "bool_handling": "flag-negation",
    "order": 2
}